{
  "expo": {
    "name": "paperflow",
    "slug": "paperflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "paperflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown Document",
            "LSItemContentTypes": [
              "net.daringfireball.markdown",
              "public.plain-text"
            ],
            "LSHandlerRank": "Alternate",
            "CFBundleTypeRole": "Editor"
          }
        ],
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "net.daringfireball.markdown",
            "UTTypeConformsTo": ["public.plain-text"],
            "UTTypeDescription": "Markdown",
            "UTTypeTagSpecification": {
              "public.filename-extension": ["md", "markdown", "mdown", "mkd"],
              "public.mime-type": ["text/markdown", "text/x-markdown"]
            }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.the25thdecoy.paperflow",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "file", "mimeType": "text/markdown" },
            { "scheme": "content", "mimeType": "text/markdown" },
            { "scheme": "file", "mimeType": "text/x-markdown" },
            { "scheme": "content", "mimeType": "text/x-markdown" },
            { "scheme": "file", "pathPattern": ".*\\.md" },
            { "scheme": "content", "pathPattern": ".*\\.md" },
            { "scheme": "file", "pathPattern": ".*\\.markdown" },
            { "scheme": "content", "pathPattern": ".*\\.markdown" }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b29f6868-3bb9-485f-9dbb-ad58dacbc4e1"
      }
    },
    "owner": "the25thdecoy"
  }
}
